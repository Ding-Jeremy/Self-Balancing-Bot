{
"latex-workshop.latex.tools": [
  {
    "name": "latexmk",
    "command": "latexmk",
    "args": [
      "-pdf",
      "-shell-escape",
      "-synctex=1",
      "-interaction=nonstopmode",
      "-use-make",
      "-outdir=build",
      "%DOC%"
    ]
  }
],

"latex-workshop.latex.recipes": [
  {
    "name": "latexmk (full)",
    "tools": ["latexmk"]
  }
]
}